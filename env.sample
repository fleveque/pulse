# NATS configuration (shared via Docker network from dividend-portfolio devcontainer)
NATS_HOST=dividend_portfolio-nats-1
NATS_PORT=4222
NATS_ENV_PREFIX=dev

# Logo service for stock logos (self-hosted)
LOGO_SERVICE_URL=https://logos.quantic.es
LOGO_SERVICE_API_KEY=your_logo_service_api_key

# Kamal deployment
KAMAL_REGISTRY_PASSWORD=your_registry_token
